# ============================
# SUPABASE CONFIG
# ============================
# Project URL dari Settings > API di dashboard Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# anon/public key dari Settings > API di dashboard Supabase
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================
# DISCORD BOT
# ============================
# Token bot dari Discord Developer Portal (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here
# ID channel tujuan notifikasi (klik kanan channel → Copy Channel ID)
DISCORD_CHANNEL_ID=your_channel_id_here

# ============================
# ANIME API
# ============================
# URL API anime ongoing (bisa diganti jika endpoint berubah)
ANIME_API_URL=your_api_key

# ============================
# WEBSITE
# ============================
# Base URL website kamu untuk link "Tonton Sekarang" di embed Discord
SITE_BASE_URL=your_website

# ============================
# BOT IDENTITY
# ============================
# Nama bot yang muncul di Discord (avatar diatur langsung di settings webhook Discord)
BOT_NAME=your_botname

# ============================
# SCRAPER API
# ============================
# API key dari scraperapi.com untuk bypass hotlink protection saat download thumbnail
SCRAPER_API_KEY=your_scraperapi_key_here

# ============================
# SCHEDULER CONFIG
# ============================
# Interval pengecekan dalam jam (default: 2)
CHECK_INTERVAL_HOURS=2

# Timezone untuk scheduler (default: Asia/Jakarta)
TIMEZONE=Asia/Jakarta
